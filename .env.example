NEXT_PUBLIC_APP_URL=http://localhost:3000

BETTER_AUTH_SECRET=your-secret-key
BETTER_AUTH_URL=http://localhost:3000

# ------------------------ Database URLs ------------------------
# DATABASE_URL: For the application (Next.js / PrismaClient).
# DATABASE_URL_UNPOOLED: For the Prisma CLI (migrate / db push / introspect).
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ------------------------ OAuth Providers ------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

RESEND_API_KEY=your-resend-api-key

# ------------------------ MCP ------------------------
NEON_MCP_TOKEN=your-neon-mcp-token
ENABLE_DEV_MCP=true
